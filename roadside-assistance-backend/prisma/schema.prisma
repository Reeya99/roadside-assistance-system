generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  role          String   @default("user") // user, mechanic, admin
  profileImage  String?
  isVerified    Boolean  @default(false)
  status        String   @default("active") // active, blocked
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicles      Vehicle[]
  mechanic      Mechanic?
  requests      ServiceRequest[] @relation("UserRequests")
  reviews       Review[]
  notifications Notification[]
  complaints    Complaint[]      @relation("UserComplaints")
  complaintsAgainst Complaint[]  @relation("ComplaintsAgainstUser")
  adminLogs     AdminLog[]
}

model Vehicle {
  id              String   @id @default(uuid())
  userId          String
  vehicleNumber   String
  vehicleType     String   // car, bike, truck, etc.
  brand           String
  model           String
  year            Int
  color           String
  insuranceNumber String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  serviceRequests ServiceRequest[]
}

model Mechanic {
  id              String   @id @default(uuid())
  userId          String   @unique
  isVerified      Boolean  @default(false)
  experience      Int?
  servicesOffered String[] // Array of strings
  about           String?
  rating          Float    @default(0)
  currentLocation Json?    // { latitude, longitude }
  isAvailable     Boolean  @default(true)
  walletBalance   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  mechanicServices MechanicService[]
  serviceRequests ServiceRequest[] @relation("MechanicRequests")
  trackings       Tracking[]
  reviews         Review[]
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mechanicServices MechanicService[]
  serviceRequests  ServiceRequest[]
}

model MechanicService {
  id          String   @id @default(uuid())
  mechanicId  String
  serviceId   String
  price       Float
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  mechanic    Mechanic @relation(fields: [mechanicId], references: [id])
  service     Service  @relation(fields: [serviceId], references: [id])
}

model ServiceRequest {
  id             String    @id @default(uuid())
  userId         String
  vehicleId      String
  mechanicId     String?
  serviceId      String
  pickupLocation Json      // { latitude, longitude, address }
  dropLocation   Json?     // { latitude, longitude, address }
  scheduledAt    DateTime?
  description    String?
  status         String    @default("requested") // requested, accepted, on_the_way, arrived, completed, cancelled
  estimatedPrice Float?
  finalPrice     Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation("UserRequests", fields: [userId], references: [id])
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
  mechanic       Mechanic? @relation("MechanicRequests", fields: [mechanicId], references: [id])
  service        Service   @relation(fields: [serviceId], references: [id])

  tracking       Tracking[]
  review         Review?
  payment        Payment?
  complaint      Complaint[]
}

model Tracking {
  id          String   @id @default(uuid())
  requestId   String
  mechanicId  String
  latitude    Float
  longitude   Float
  timestamp   DateTime @default(now())

  request     ServiceRequest @relation(fields: [requestId], references: [id])
  mechanic    Mechanic       @relation(fields: [mechanicId], references: [id])
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  mechanicId  String
  requestId   String   @unique
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  user        User           @relation(fields: [userId], references: [id])
  mechanic    Mechanic       @relation(fields: [mechanicId], references: [id])
  request     ServiceRequest @relation(fields: [requestId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // info, success, warning, error
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id            String    @id @default(uuid())
  requestId     String    @unique
  amount        Float
  method        String    // card, wallet, cash, other
  status        String    @default("pending") // pending, paid, failed, refunded
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  request       ServiceRequest @relation(fields: [requestId], references: [id])
}

model Complaint {
  id            String   @id @default(uuid())
  userId        String
  requestId     String
  againstUserId String
  reason        String
  description   String?
  status        String   @default("open") // open, in_progress, resolved, closed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User           @relation("UserComplaints", fields: [userId], references: [id])
  againstUser   User           @relation("ComplaintsAgainstUser", fields: [againstUserId], references: [id])
  request       ServiceRequest @relation(fields: [requestId], references: [id])
}

model AdminLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  targetType  String   // user, mechanic, request, service, etc.
  targetId    String
  description String?
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id])
}
